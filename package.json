{
  "name": "relay",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @relay/api --filter @relay/gateway --filter @relay/web dev",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "dev:web": "corepack pnpm --filter @relay/web dev",
    "dev:api": "corepack pnpm --filter @relay/api dev",
    "dev:gateway": "corepack pnpm --filter @relay/gateway dev",
    "dev:admin": "corepack pnpm --filter @relay/admin dev",
    "dev:desktop": "corepack pnpm --filter @relay/desktop dev"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3"
  }
}
